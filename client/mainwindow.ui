  <property name="styleSheet">
   <string notr="true">QMainWindow {
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
    stop:0 #F0F0F0, stop:1 #E8E8E8);
  border-radius: 24px;
}
#centralWidget, #overlay, #statusBar, #centerArea, #bottomArea {
  background: transparent;
}
#timeLabel {
  color: #FFFFFF;
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 24px;
  font-weight: 500;
}
#voiceHintLabel {
  color: #FFFFFF;
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 20px;
  font-weight: 500;
}
#transcriptionLabel {
  color: #FFFFFF;
  font-family: 'Inter', -apple-system, sans-serif;
  font-size: 16px;
  font-weight: 400;
  background: rgba(0,0,0,0.35);
  border-radius: 12px;
  padding: 8px 12px;
}
/* === 底部 4 个圆形按钮 (对应 docs/gui.html L85-113) === */
QPushButton#micButton, QPushButton#sendButton,
QPushButton#videoButton, QPushButton#endCallButton {
  border: none;
  border-radius: 40px;
  font-weight: bold;
}
/* 按钮 1: 麦克风 (默认态) - bg-white/90 */
QPushButton#micButton {
  background: rgba(255,255,255,0.90);
  color: #444444;
  font-size: 34px;
}
QPushButton#micButton:hover { background: rgba(255,255,255,1.0); }
/* 按钮 1: 麦克风激活态 (绿色) */
QPushButton#micButton:checked {
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 30px;
}
QPushButton#micButton:checked:hover { background: #5DBE61; }
/* 按钮 2: 发送/上传 - bg-white/70 */
QPushButton#sendButton {
  background: rgba(255,255,255,0.70);
  color: #555555;
  font-size: 30px;
}
QPushButton#sendButton:hover { background: rgba(255,255,255,0.85); }
QPushButton#sendButton:pressed { background: rgba(255,255,255,0.95); color: #333333; }
/* 按钮 3: 视频通话 (默认态) - bg-white */
QPushButton#videoButton {
  background: #FFFFFF;
  color: #000000;
  font-size: 32px;
}
QPushButton#videoButton:hover { background: rgba(255,255,255,0.92); }
/* 按钮 3: 视频通话激活态 (红色录制中) */
QPushButton#videoButton:checked {
  background: #FF3B30;
  color: #FFFFFF;
  font-size: 22px;
}
QPushButton#videoButton:checked:hover { background: #FF5147; }
/* 按钮 4: 结束通话 - bg-white/90, 红色 X */
QPushButton#endCallButton {
  background: rgba(255,255,255,0.90);
  color: #FF3B30;
  font-size: 38px;
}
QPushButton#endCallButton:hover { background: rgba(255,255,255,1.0); }
</string>
